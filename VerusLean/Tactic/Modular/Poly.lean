-- Example from page 90 of Ideals book

--    x³ - 2xy
def p₁ : Polynomial := #[MTerm.mk 1 #[3, 0], MTerm.mk (-2) #[1, 1]]
#eval p₁.toString

--    x²y - 2y² + x
def p₂ : Polynomial := #[MTerm.mk 1 #[2, 1], MTerm.mk (-2) #[0, 2], MTerm.mk 1 #[1, 0]]
#eval p₂.toString

--     x²
def p_mem : Polynomial := #[MTerm.mk 1 #[2, 0]]

-- Expected: #[x1^2, x1 * x2, x2^2 - 1/2 x1]
#eval Polynomial.buchbergers #[p₁, p₂]
#eval HPoly.buchbergers #[p₁, p₂] |>.map (fun | .mk p _ => p)

-- Expected: [-x2, x1], since   x² = (-y) (x³ - 2xy) + (x) (x²y - 2y² + x)
#eval HPoly.idealMembership p_mem #[p₁, p₂]
#eval timeit "time elapsed" do
  match HPoly.idealMembership p_mem #[p₁, p₂] with
  | .inl () => IO.println "No witness found"
  | .inr w =>
    let wStr := w.foldl (init := "[\n") (λ str p => str ++ s!" {p},\n")
    IO.println s!"Witness found: {wStr}]"
  return ()

