-- Example from John Harrison's paper

-- On variables [a, d, n, u, v, x, y]

--      ay - ax - dn
def p₃ : Polynomial := #[MTerm.mk 1 #[1, 0, 0, 0, 0, 0, 1], MTerm.mk (-1) #[1, 0, 0, 0, 0, 1, 0], MTerm.mk (-1) #[0, 1, 1, 0, 0, 0, 0]]

--      au + nv - 1
def p₄ : Polynomial := #[MTerm.mk 1 #[1, 0, 0, 1, 0, 0, 0], MTerm.mk 1 #[0, 0, 1, 0, 1, 0, 0], MTerm.mk (-1) #[0, 0, 0, 0, 0, 0, 0]]

--      n
def p₅ : Polynomial := #[MTerm.mk 1 #[0, 0, 1, 0, 0, 0, 0]]

--      y - x
def p₆ : Polynomial := #[MTerm.mk (-1) #[0, 0, 0, 0, 0, 1, 0], MTerm.mk 1 #[0, 0, 0, 0, 0, 0, 1]]

/-
  The answer/certificate that Harrison provides is

    ( u,    x - y,      ud + vy - vx),

  which translates to

    #[x4, x6 - x7, x2 * x4 + x5 * x7 - x5 * x6]

-/
#eval Polynomial.buchbergers #[p₃, p₄, p₅]
#eval HPoly.idealMembership p₆ #[p₃, p₄, p₅]

#eval timeit "time elapsed" do
  match HPoly.idealMembership p₆ #[p₃, p₄, p₅] with
  | .inl () => IO.println "No witness found"
  | .inr w =>
    let wStr := w.foldl (init := "[\n") (λ str p => str ++ s!" {p},\n")
    IO.println s!"Witness found: {wStr}]"
  return ()
